# ─── Anthropic (for investment thesis generation) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs (create in Stripe dashboard → Products)
STRIPE_PRICE_PRO=price_...               # €149/mo
STRIPE_PRICE_INVESTOR=price_...          # €499/mo
STRIPE_PRICE_INSTITUTIONAL=price_...     # custom / contact us

# ─── Resend ───────────────────────────────────────────────────────────────────
